│   ├── 03_evaluate_baseline.py
│   ├── 04_threshold_analysis.py
│   ├── 05_quantize_tflite.py
│   ├── 06_predict_image.py
│   ├── 07_predict_tflite.py
│   └── config.py
│
├── models/
│   ├── baseline.keras
│   ├── int8.tflite
